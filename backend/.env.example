# Database — use sqlite+libsql:// for Turso, sqlite:// for local dev
DATABASE_URL=sqlite:///./poker_lab.db

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Set to "production" to enforce stricter security
ENVIRONMENT=development

# Optional: OpenRouter API key for AI coaching (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
